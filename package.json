{
  "name": "ai-oa-practice",
  "private": true,
  "version": "0.1.0",
  "description": "AI-powered technical interview practice platform",
  "workspaces": [
    "frontend/react-app",
    "backend/node-server"
  ],
  "scripts": {
    "dev:frontend": "npm --prefix frontend/react-app run dev",
    "dev:backend": "npm --prefix backend/node-server run dev",
    "build:frontend": "npm --prefix frontend/react-app run build",
    "build:backend": "npm --prefix backend/node-server run build",
    "build": "npm run build:frontend && npm run build:backend",
    "lint:frontend": "npm --prefix frontend/react-app run lint",
    "typecheck:backend": "npm --prefix backend/node-server run typecheck"
  },
  "engines": {
    "node": ">=20.18.1"
  },
  "license": "MIT"
}
